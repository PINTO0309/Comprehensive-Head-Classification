{
  "name": "chc-web-benchmark",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "prepare:assets": "node scripts/prepare-assets.mjs",
    "dev": "node scripts/dev.mjs",
    "build": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.electron.json && vite build",
    "preview": "node scripts/preview.mjs",
    "benchmark:wasm": "node scripts/benchmark.mjs wasm",
    "benchmark:webgpu": "node scripts/benchmark.mjs webgpu",
    "benchmark:litert:wasm": "node scripts/benchmark.mjs litert wasm",
    "benchmark:litert:webgpu": "node scripts/benchmark.mjs litert webgpu",
    "benchmark:demo:wasm": "node scripts/benchmark.mjs demo wasm",
    "benchmark:demo:webgpu": "node scripts/benchmark.mjs demo webgpu",
    "benchmark:demo:litert:wasm": "node scripts/benchmark.mjs demo litert wasm",
    "benchmark:demo:litert:webgpu": "node scripts/benchmark.mjs demo litert webgpu"
  },
  "dependencies": {
    "@litertjs/core": "2.5.2",
    "onnxruntime-web": "1.27.0"
  },
  "devDependencies": {
    "@types/node": "22.20.0",
    "electron": "42.5.1",
    "typescript": "6.0.3",
    "vite": "8.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ]
  },
  "engines": {
    "node": ">=22.12.0",
    "pnpm": "10.33.0"
  }
}

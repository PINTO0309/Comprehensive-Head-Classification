{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": false,
    "rootDir": "electron",
    "outDir": "dist-electron",
    "types": ["node", "electron"]
  },
  "include": ["electron"]
}
